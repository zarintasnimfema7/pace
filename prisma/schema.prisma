datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ==========================================
// USER & SYSTEM AUTHENTICATION (Auth.js Compatible)
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // OAuth Account linkages
  accounts      Account[]
  sessions      Session[]

  // Relational Links to the 6 Pillars
  habits        Habit[]
  habitLogs     HabitLog[]
  tasks         Task[]
  books         Book[]
  focusSessions FocusSession[] // 👈 ADD THIS LINE HERE TO SOLVE THE COMPILER MISMATCH
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// PILLAR 1 & 2: DAILY RITUALS & HABIT INVENTORY
// ==========================================
model Habit {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  frequency   String     @default("DAILY") // "DAILY", "WEEKLY", "CUSTOM"
  customCount Int?       // Stores the integer value if frequency is "CUSTOM" (e.g., 4 times a week)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        HabitLog[]

  @@index([userId])
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  userId      String
  date        DateTime // Normalized to midnight (YYYY-MM-DD 00:00:00) for clean matrix matching
  createdAt   DateTime @default(now())

  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Enforces that a specific habit can only have a single entry per day
  @@unique([habitId, date])
  @@index([habitId])
  @@index([userId])
}
// ==========================================
// PILLAR 3: THE COMMAND CENTER
// ==========================================
model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  priority    Priority  @default(MEDIUM)
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ==========================================
// PILLARS 5 & 6: MONTHLY TBR & GRAND LIBRARY
// ==========================================
// ==========================================
// PILLARS 5 & 6: MONTHLY TBR & GRAND LIBRARY
// ==========================================
enum BookStatus {
  WANT_TO_READ
  COMPLETED
}

model Book {
  id          String      @id @default(cuid())
  userId      String
  title       String
  author      String?     
  status      BookStatus  @default(WANT_TO_READ)
  month       String      
  year        Int         
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}





enum FocusStatus {
  SUCCESS
  FAILED
}

model FocusSession {
  id        String      @id @default(cuid())
  userId    String
  duration  Int         // Total minutes attempted (e.g., 25)
  status    FocusStatus
  createdAt DateTime    @default(now())

  // Relationship back to the User model
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}